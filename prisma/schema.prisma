generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Ruta {
  id            Int        @id @default(autoincrement())
  nombre        String
  activo        Boolean    @default(true)
  fechaCreacion DateTime   @default(now())
  clientes      Cliente[]
  prestamos     Prestamo[]
  usuarios      Usuario[]
  cajas         Caja[]
}

model Cliente {
  id                Int        @id @default(autoincrement())
  nombreCompleto    String
  celular           String
  direccionNegocio  String?
  direccionVivienda String?
  fechaCreacion     DateTime
  rutaId            Int
  ruta              Ruta       @relation(fields: [rutaId], references: [id])
  prestamos         Prestamo[]
  @@index([rutaId])
}

model Usuario {
  id             Int              @id @default(autoincrement())
  nombreCompleto String
  celular        String
  email          String           @unique
  alias          String?
  rol            Rol
  fechaCreacion  DateTime
  placaMoto      String?
  fechaTecnico   DateTime?
  fechaSoat      DateTime?
  password       String?
  rutaId         Int?
  ruta           Ruta?            @relation(fields: [rutaId], references: [id])
  abonos         Abono[]
  prestamos      Prestamo[]       @relation("prestamosCobrador")
  permisos       UsuarioPermiso[]
  @@index([rutaId])
}

model UsuarioPermiso {
  usuarioId Int
  permiso   Permiso
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  @@id([usuarioId, permiso])
  @@index([usuarioId])
}

model Prestamo {
  id            Int      @id @default(autoincrement())
  clienteId     Int
  fechaInicio   DateTime
  montoPrestado Decimal
  /// Estado del préstamo: ACTIVO / INACTIVO / CANCELADO
  estado        EstadoPrestamo @default(ACTIVO)
  tasa          Float
  cuotas        Int
  cobradorId    Int
  notas         String?
  orden         Int
  rutaId        Int
  ruta          Ruta     @relation(fields: [rutaId], references: [id])
  abonos        Abono[]
  cliente       Cliente  @relation(fields: [clienteId], references: [id])
  cobrador      Usuario  @relation("prestamosCobrador", fields: [cobradorId], references: [id])
  @@index([estado])
  @@index([rutaId])
}

model Abono {
  id         Int      @id @default(autoincrement())
  prestamoId Int
  cobradorId Int
  fecha      DateTime
  monto      Decimal
  tipoPago   String
  notas      String?
  cobrador   Usuario  @relation(fields: [cobradorId], references: [id])
  prestamo   Prestamo @relation(fields: [prestamoId], references: [id])
}

model Caja {
  id     Int            @id @default(autoincrement())
  fecha  DateTime
  tipo   MovimientoTipo
  monto  Decimal
  nota   String?
  rutaId Int?
  ruta   Ruta?          @relation(fields: [rutaId], references: [id])
  @@index([rutaId])
}

enum Rol {
  ADMIN
  COBRADOR
  USUARIO
}

enum Permiso {
  CLIENTES_READ
  CLIENTES_CREATE
  CLIENTES_UPDATE
  CLIENTES_DELETE
  PRESTAMOS_READ
  PRESTAMOS_CREATE
  PRESTAMOS_UPDATE
  PRESTAMOS_DELETE
  ABONOS_READ
  ABONOS_CREATE
  ABONOS_UPDATE
  ABONOS_DELETE
  CAJA_READ
  CAJA_CREATE
  CAJA_UPDATE
  CAJA_DELETE
  RUTAS_READ
  RUTAS_CREATE
  RUTAS_UPDATE
  RUTAS_DELETE
  REPORTES_VIEW
}

enum MovimientoTipo {
  GASTO
  ENTRADA
  SALIDA
  SALIDA_RUTA
  ENTRADA_RUTA
}

enum EstadoPrestamo {
  ACTIVO
  INACTIVO
  CANCELADO
}
